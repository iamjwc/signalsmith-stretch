{
	"compilerOptions": {
		"target": "ES2020",
		"module": "none",
		"lib": ["es2020", "dom", "dom.iterable", "webworker"],
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"declarationDir": "dist/types",
		"removeComments": false,
		"useDefineForClassFields": false
	},
	"include": ["src/**/*.ts"]
}
